# FCC Radio Map - Production Configuration
# Copy this file to .env and edit with your settings

# ============================================================================
# Database Configuration
# ============================================================================
FCC_DATABASE_URL=postgresql+asyncpg://fcc:fcc@db:5432/fcc
FCC_DATABASE_SYNC_URL=postgresql://fcc:fcc@db:5432/fcc

# ============================================================================
# FCC Data Sources
# ============================================================================
FCC_FCC_BULK_URL=https://data.fcc.gov/download/pub/uls/complete/
FCC_FCC_WEEKLY_URL=https://data.fcc.gov/download/pub/uls/daily/
FCC_FCC_DATA_DIR=./data/fcc_downloads

# ============================================================================
# Application Settings
# ============================================================================
FCC_APP_TITLE=FCC Radio License Map
FCC_DEBUG=false

# ============================================================================
# Map Defaults (centered on US)
# ============================================================================
FCC_MAP_DEFAULT_LAT=39.8283
FCC_MAP_DEFAULT_LNG=-98.5795
FCC_MAP_DEFAULT_ZOOM=5
FCC_MAP_MAX_RESULTS=5000

# ============================================================================
# Caching (Optional - improves performance)
# ============================================================================
# FCC_REDIS_URL=redis://localhost:6379/0
FCC_CACHE_TTL=3600

# ============================================================================
# Security (Optional - for production)
# ============================================================================
# Set to comma-separated list of allowed hosts for your domain
# FCC_ALLOWED_HOSTS=example.com,www.example.com

# ============================================================================
# Logging (Optional)
# ============================================================================
# LOG_LEVEL can be: DEBUG, INFO, WARNING, ERROR, CRITICAL
# FCC_LOG_LEVEL=INFO
